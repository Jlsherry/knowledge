# 阿里云 DashScope API Key（通义千问 / Embedding）
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Qwen 对话模型，可选: qwen-turbo / qwen-plus / qwen-max
QWEN_MODEL=qwen-plus

# Embedding 模型
EMBEDDING_MODEL=text-embedding-v3

# SQLite 数据库路径（相对 backend 目录）
DATABASE_URL=sqlite:///./data/app.db
# 启动时会自动执行 schema 迁移（见 app/migrations）；也可手动运行：python -m app.migrations status

# Chroma 向量库持久化目录
CHROMA_PERSIST_DIR=./data/chroma

# BM25 索引缓存目录
BM25_CACHE_DIR=./data/bm25

# 上传文件存储目录
UPLOAD_DIR=./data/uploads

# 文本分块参数
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# RAG 检索配置
RETRIEVAL_TOP_K=5
# 检索方式：similarity / mmr
RETRIEVAL_SEARCH_TYPE=mmr
# MMR 候选池大小（建议为 TOP_K 的 3~5 倍）
RETRIEVAL_FETCH_K=20
# MMR 相关性权重：1.0 等同 similarity，0.5 平衡多样性
RETRIEVAL_LAMBDA_MULT=0.5
# 引用来源展示的最大字符数（建议 300~500）
SOURCE_SNIPPET_MAX_LEN=400

# 多轮对话保留的历史轮数（user+assistant 算一轮）
MAX_HISTORY_TURNS=5
